#!/usr/bin/env node
import { readFile } from "node:fs/promises";
import { basename, extname } from "node:path";

const base = (process.env.CANVAS_SIDECAR_URL || "http://127.0.0.1:4317").replace(/\/$/, "");
const token = process.env.CANVAS_TOKEN;
if (!token) fail("CANVAS_TOKEN is not set. Start this through the Codex Canvas sidecar.");
const [command, ...args] = process.argv.slice(2);

try {
  let result;
  if (command === "snapshot") result = await request(`/api/snapshot${args.includes("--full") ? "?full=1" : ""}`);
  else if (command === "eval") {
    const fileIndex = args.indexOf("--file");
    const code = fileIndex >= 0 ? await readFile(args[fileIndex + 1], "utf8") : args.join(" ");
    result = await action("eval", { code });
  } else if (command === "create" || command === "update") result = await action(command, JSON.parse(args.join(" ")));
  else if (command === "delete") result = await action("delete", { ids: args });
  else if (command === "clear" || command === "zoomToFit") result = await action(command);
  else if (command === "image") result = await image(args);
  else if (command === "health") result = await request("/health", {}, false);
  else usage();
  process.stdout.write(`${JSON.stringify(result, null, 2)}\n`);
} catch (error) { fail(error instanceof Error ? error.message : String(error)); }

async function image(args) {
  const source = args[0];
  if (!source) throw new Error("image requires a local file path or URL");
  let url = source;
  let name = basename(source);
  let mimeType = mime(extname(source));
  if (!/^https?:\/\//.test(source) && !/^data:/.test(source)) {
    const dataBase64 = (await readFile(source)).toString("base64");
    const uploaded = await request("/api/assets", { method: "POST", body: JSON.stringify({ name, mimeType, dataBase64 }) });
    url = uploaded.url;
  }
  const options = flags(args.slice(1));
  return action("image", { url, name, mimeType, x: number(options.x, 0), y: number(options.y, 0), width: number(options.width, 640), height: number(options.height, 480), alt: options.alt || name });
}
async function action(action, payload) { return (await request("/api/command", { method: "POST", body: JSON.stringify({ action, payload }) })).result; }
async function request(path, options = {}, auth = true) {
  const response = await fetch(`${base}${path}`, { ...options, headers: { "content-type": "application/json", ...(auth ? { authorization: `Bearer ${token}` } : {}), ...(options.headers || {}) } });
  const body = await response.json();
  if (!response.ok) throw new Error(body.error || `${response.status} ${response.statusText}`);
  return body;
}
function flags(values) { const out = {}; for (let i = 0; i < values.length; i += 2) if (values[i]?.startsWith("--")) out[values[i].slice(2)] = values[i + 1]; return out; }
function number(value, fallback) { const parsed = Number(value); return Number.isFinite(parsed) ? parsed : fallback; }
function mime(extension) { return ({ ".png": "image/png", ".jpg": "image/jpeg", ".jpeg": "image/jpeg", ".gif": "image/gif", ".webp": "image/webp", ".svg": "image/svg+xml" })[extension.toLowerCase()] || "application/octet-stream"; }
function fail(text) { process.stderr.write(`${text}\n`); process.exit(1); }
function usage() { process.stdout.write(`canvasctl commands:\n  snapshot [--full]\n  create '<shape-or-array-json>'\n  update '<partial-shape-or-array-json>'\n  delete shape:id ...\n  image <file-or-url> [--x N --y N --width N --height N --alt text]\n  eval '<javascript using editor, tldraw, payload>'\n  eval --file script.js\n  clear\n  zoomToFit\n`); process.exit(0); }
