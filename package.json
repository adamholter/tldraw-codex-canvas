{
  "name": "tldraw-codex-canvas",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "codex-canvas": "./bin/codex-canvas"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "sidecar": "node scripts/start-web-sidecar.mjs",
    "sidecar:local": "node scripts/sidecar.mjs --web-url http://localhost:3000",
    "sidecar:web": "node scripts/start-web-sidecar.mjs",
    "setup": "node scripts/setup.mjs",
    "canvas": "bin/canvasctl",
    "qa:e2e": "node scripts/e2e.mjs",
    "test": "npm run build",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "@tldraw/editor": "^5.2.4",
    "@tldraw/tlschema": "^5.2.4",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "t3-code-ultralight-browser-fork": "https://github.com/adamholter/t3-code-ultralight-browser-fork/releases/latest/download/t3-code-ultralight-browser-fork.tgz?v=0.55.0",
    "tldraw": "^5.2.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.13",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
